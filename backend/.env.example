# .env.example for BACKEND (Node.js)
# -------------------------------------------------------
# Copy this file and rename it to ".env" (remove .example)
# Then fill in your actual values below.
# NEVER commit your real .env file to GitHub!
# -------------------------------------------------------

# Port this server runs on (default is 5000)
PORT=5000

# The URL of your frontend app (used for CORS)
FRONTEND_URL=http://localhost:5173

# URL of your Supabase project (found in Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Service Role key for Supabase (has full access — keep this SECRET!)
# Found in Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# URL where our Python AI service is running
AI_SERVICE_URL=http://localhost:8000
