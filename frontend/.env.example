# .env.example for FRONTEND
# -------------------------------------------------------
# Copy this file and rename it to ".env" (remove .example)
# Then fill in your actual values below.
# NEVER commit your real .env file to GitHub!
# -------------------------------------------------------

# URL of your Supabase project (found in Supabase dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous key from Supabase (safe to use on the frontend)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# The URL where our Node.js backend is running
# During development, this will be localhost
VITE_BACKEND_URL=http://localhost:5000

# The URL where our Python AI service is running
VITE_AI_SERVICE_URL=http://localhost:8000
