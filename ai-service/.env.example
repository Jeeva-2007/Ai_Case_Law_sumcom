# .env.example for AI SERVICE (Python)
# -------------------------------------------------------
# Copy this file and rename it to ".env" (remove .example)
# Then fill in your actual values below.
# NEVER commit your real .env file to GitHub!
# -------------------------------------------------------

# Port this Python service runs on (default is 8000)
PORT=8000

# URL of the Node.js backend (in case AI service needs to notify backend)
BACKEND_URL=http://localhost:5000

# Ollama Configuration
# Ollama runs AI models locally on your machine
# Default URL when Ollama is installed and running
OLLAMA_BASE_URL=http://localhost:11434

# The name of the AI model to use via Ollama

# Run 'ollama list' in terminal to see what you have installed
OLLAMA_MODEL=qwen2.5:0.5b   

# Hugging Face Token (optional — only needed if using gated HF models)
# Get your token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=your-huggingface-token-here
